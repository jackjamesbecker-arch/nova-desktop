{
  "name": "nova-apex",
  "version": "1.0.0",
  "description": "NOVA QC-7 — APEX Intelligence AI System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.apex.nova",
    "productName": "NOVA",
    "copyright": "APEX Intelligence Division",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NOVA",
      "license": "NOVA_LICENSE.txt"
    },
    "extraResources": [
      { "from": "assets", "to": "assets" }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
